              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "max_version",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "reload_interval",
              "required": false,
              "type": {
                "kind": "duration"
              }
            },
            {
              "name": "cipher_suites",
