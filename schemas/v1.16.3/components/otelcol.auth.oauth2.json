              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "curve_preferences",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            },
            {
              "name": "insecure",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "insecure_skip_verify",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "server_name",
              "required": false,
              "type": {
                "kind": "string"
              }
            }
          ],
          "blocks": [
            {
              "name": "tpm",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "enabled",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "path",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "owner_auth",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "auth",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "name": "debug_metrics",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "disable_high_cardinality_metrics",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "level",
              "required": false,
              "default": "detailed",
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      }
