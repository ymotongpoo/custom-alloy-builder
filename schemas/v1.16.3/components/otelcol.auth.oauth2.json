        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "client_certificate_key_id",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "client_certificate_key",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "client_certificate_key_file",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "grant_type",
        "required": false,
