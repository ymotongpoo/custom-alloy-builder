        "type": {
          "kind": "map",
          "value": {
            "kind": "raw",
            "goType": "interface {}"
          }
        }
      },
      {
        "name": "token_url",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "endpoint_params",
