        "type": {
          "kind": "string"
        }
      },
      {
        "name": "signature_algorithm",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "iss",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "audience",
        "required": false,
        "type": {
          "kind": "string"
        }
