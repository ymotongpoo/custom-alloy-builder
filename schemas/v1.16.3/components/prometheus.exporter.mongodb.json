{
  "name": "prometheus.exporter.mongodb",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/exporter/mongodb",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "mongodb_uri",
        "required": true,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "compatible_mode",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "collect_all",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "direct_connect",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "discovering_mode",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_db_stats",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_db_stats_free_storage",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_diagnostic_data",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_replicaset_status",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_replicaset_config",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_currentop_metrics",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_top_metrics",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_index_stats",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_coll_stats",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_profile",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_shards",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_fcv",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_pbm_metrics",
        "required": false,
        "type": {
          "kind": "bool"
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
