{
  "name": "discovery.digitalocean",
  "importPath": "github.com/grafana/alloy/internal/component/discovery/digitalocean",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "refresh_interval",
        "required": false,
        "default": "1m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "port",
        "required": false,
        "default": 80,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "bearer_token",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "bearer_token_file",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "proxy_url",
        "required": false,
        "type": {
          "kind": "raw",
          "goType": "config.URL"
        }
      },
      {
        "name": "no_proxy",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "proxy_from_environment",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "proxy_connect_header",
        "required": false,
        "type": {
          "kind": "map",
          "value": {
            "kind": "list",
            "elem": {
              "kind": "secret"
            }
          }
        }
      },
      {
        "name": "follow_redirects",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_http2",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "http_headers",
        "required": false,
        "type": {
          "kind": "map",
          "value": {
            "kind": "list",
            "elem": {
              "kind": "secret"
            }
          }
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
