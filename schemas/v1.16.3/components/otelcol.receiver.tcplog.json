              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "line_end_pattern",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "omit_pattern",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ]
        }
      },
      {
