{
  "name": "otelcol.exporter.googlecloud",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/exporter/googlecloud",
  "stability": "undefined",
  "community": true,
  "arguments": {
    "attributes": [
      {
        "name": "project",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "destination_project_quota",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "user_agent",
        "required": false,
        "default": "opentelemetry-collector-contrib {{version}}",
        "type": {
          "kind": "string"
        }
      }
    ],
    "blocks": [
      {
        "name": "sending_queue",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "enabled",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "num_consumers",
              "required": false,
              "default": 10,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "queue_size",
              "required": false,
              "default": 1000,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "block_on_overflow",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "sizer",
              "required": false,
              "default": "requests",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "wait_for_result",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "storage",
              "required": false,
              "type": {
                "kind": "raw",
                "goType": "extension.ExtensionHandler"
              }
            }
          ],
          "blocks": [
            {
              "name": "batch",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "flush_timeout",
                    "required": false,
                    "default": "200ms",
                    "type": {
                      "kind": "duration"
                    }
                  },
                  {
                    "name": "min_size",
                    "required": false,
                    "default": 2000,
                    "type": {
                      "kind": "number"
                    }
                  },
                  {
                    "name": "max_size",
                    "required": false,
                    "default": 3000,
                    "type": {
                      "kind": "number"
                    }
                  },
                  {
                    "name": "sizer",
                    "required": false,
                    "default": "items",
                    "type": {
                      "kind": "string"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "name": "impersonate",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "target_principal",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "subject",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "delegates",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            }
          ]
        }
      },
      {
        "name": "metric",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "prefix",
              "required": false,
              "default": "workload.googleapis.com",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "endpoint",
              "required": false,
              "default": "monitoring.googleapis.com:443",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "compression",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "grpc_pool_size",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "use_insecure",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "known_domains",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            },
            {
              "name": "skip_create_descriptor",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "instrumentation_library_labels",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "create_service_timeseries",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "create_metric_descriptor_buffer_size",
              "required": false,
              "default": 10,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "service_resource_labels",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "resource_filters",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "raw",
                  "goType": "googlecloudconfig.ResourceFilter"
                }
              }
            },
            {
              "name": "cumulative_normalization",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "sum_of_squared_deviation",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ],
          "blocks": [
            {
              "name": "experimental_wal",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "directory",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "max_backoff",
                    "required": false,
                    "type": {
                      "kind": "duration"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "name": "trace",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "endpoint",
              "required": false,
              "default": "cloudtrace.googleapis.com:443",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "grpc_pool_size",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "use_insecure",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "attribute_mappings",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "raw",
                  "goType": "googlecloudconfig.AttributeMappings"
                }
              }
            }
          ]
        }
      },
      {
        "name": "log",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "endpoint",
              "required": false,
              "default": "logging.googleapis.com:443",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "compression",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "grpc_pool_size",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "use_insecure",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "default_log_name",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "resource_filters",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "raw",
                  "goType": "googlecloudconfig.ResourceFilter"
                }
              }
            },
            {
              "name": "service_resource_labels",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "error_reporting_type",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ]
        }
      },
      {
        "name": "debug_metrics",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "disable_high_cardinality_metrics",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "level",
              "required": false,
              "default": "detailed",
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "input",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "otelcol.Consumer",
          "goType": "otelcol.Consumer"
        }
      }
    ]
  }
}
