{
  "name": "otelcol.connector.servicegraph",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/connector/servicegraph",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "latency_histogram_buckets",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "duration"
          }
        }
      },
      {
        "name": "dimensions",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "cache_loop",
        "required": false,
        "default": "1m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "store_expiration_loop",
        "required": false,
        "default": "2s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "virtual_node_peer_attributes",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "virtual_node_extra_label",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "metrics_flush_interval",
        "required": false,
        "default": "1m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "database_name_attributes",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "exponential_histogram_max_size",
        "required": false,
        "type": {
          "kind": "number"
        }
      }
    ],
    "blocks": [
      {
        "name": "store",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "max_items",
              "required": false,
              "default": 1000,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "ttl",
              "required": false,
              "default": "2s",
              "type": {
                "kind": "duration"
              }
            }
          ]
        }
      },
      {
        "name": "output",
        "required": true,
        "body": {
          "attributes": [
            {
              "name": "metrics",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.metrics",
                  "goType": "otelcol.Consumer"
                }
              }
            },
            {
              "name": "logs",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.logs",
                  "goType": "otelcol.Consumer"
                }
              }
            },
            {
              "name": "traces",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.traces",
                  "goType": "otelcol.Consumer"
                }
              }
            }
          ]
        }
      },
      {
        "name": "debug_metrics",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "disable_high_cardinality_metrics",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "level",
              "required": false,
              "default": "detailed",
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "input",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "otelcol.Consumer",
          "goType": "otelcol.Consumer"
        }
      }
    ]
  }
}
