{
  "name": "prometheus.exporter.snowflake",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/exporter/snowflake",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "account_name",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "username",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "password",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "private_key_path",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "private_key_password",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "role",
        "required": false,
        "default": "ACCOUNTADMIN",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "warehouse",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "exclude_deleted_tables",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "enable_tracing",
        "required": false,
        "type": {
          "kind": "bool"
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
