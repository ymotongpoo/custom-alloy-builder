{
  "name": "loki.secretfilter",
  "importPath": "github.com/grafana/alloy/internal/component/loki/secretfilter",
  "stability": "experimental",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "forward_to",
        "required": true,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "capsule",
            "capsule": "loki.LogsReceiver",
            "goType": "loki.LogsReceiver"
          }
        }
      },
      {
        "name": "origin_label",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "redact_with",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "redact_percent",
        "required": false,
        "default": 80,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "gitleaks_config",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "rate",
        "required": false,
        "default": 1,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "processing_timeout",
        "required": false,
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "drop_on_timeout",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "label_timed_out",
        "required": false,
        "type": {
          "kind": "bool"
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "receiver",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "loki.LogsReceiver",
          "goType": "loki.LogsReceiver"
        }
      }
    ]
  }
}
