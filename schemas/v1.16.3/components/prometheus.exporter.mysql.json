{
  "name": "prometheus.exporter.mysql",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/exporter/mysql",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "data_source_name",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "enable_collectors",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "disable_collectors",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "set_collectors",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "enable_lock_wait_timeout",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "lock_wait_timeout",
        "required": false,
        "default": 2,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "log_slow_filter",
        "required": false,
        "type": {
          "kind": "bool"
        }
      }
    ],
    "blocks": [
      {
        "name": "info_schema.processlist",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "min_time",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "processes_by_user",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "processes_by_host",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ]
        }
      },
      {
        "name": "info_schema.tables",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "databases",
              "required": false,
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      },
      {
        "name": "perf_schema.eventsstatements",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "limit",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "time_limit",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "text_limit",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "exclude_schemas",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            }
          ]
        }
      },
      {
        "name": "perf_schema.file_instances",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "filter",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "remove_prefix",
              "required": false,
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      },
      {
        "name": "perf_schema.memory_events",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "remove_prefix",
              "required": false,
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      },
      {
        "name": "heartbeat",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "database",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "table",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "utc",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ]
        }
      },
      {
        "name": "mysql.user",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "privileges",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
