{
  "name": "prometheus.exporter.squid",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/exporter/squid",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "address",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "username",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "password",
        "required": false,
        "type": {
          "kind": "secret"
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
