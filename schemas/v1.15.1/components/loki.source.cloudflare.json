{
  "name": "loki.source.cloudflare",
  "importPath": "github.com/grafana/alloy/internal/component/loki/source/cloudflare",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "api_token",
        "required": true,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "zone_id",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "labels",
        "required": false,
        "type": {
          "kind": "map",
          "value": {
            "kind": "string"
          }
        }
      },
      {
        "name": "workers",
        "required": false,
        "default": 3,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "pull_range",
        "required": false,
        "default": "1m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "fields_type",
        "required": false,
        "default": "default",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "additional_fields",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "forward_to",
        "required": true,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "capsule",
            "capsule": "loki.LogsReceiver",
            "goType": "loki.LogsReceiver"
          }
        }
      }
    ]
  },
  "exports": {}
}
