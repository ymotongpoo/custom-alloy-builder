{
  "name": "loki.source.syslog",
  "importPath": "github.com/grafana/alloy/internal/component/loki/source/syslog",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "forward_to",
        "required": true,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "capsule",
            "capsule": "loki.LogsReceiver",
            "goType": "loki.LogsReceiver"
          }
        }
      },
      {
        "name": "relabel_rules",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "raw",
            "goType": "relabel.Config"
          }
        }
      }
    ],
    "blocks": [
      {
        "name": "listener",
        "required": true,
        "multiple": true,
        "body": {
          "attributes": [
            {
              "name": "address",
              "required": true,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "protocol",
              "required": false,
              "default": "tcp",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "idle_timeout",
              "required": false,
              "default": "2m0s",
              "type": {
                "kind": "duration"
              }
            },
            {
              "name": "label_structured_data",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "labels",
              "required": false,
              "type": {
                "kind": "map",
                "value": {
                  "kind": "string"
                }
              }
            },
            {
              "name": "use_incoming_timestamp",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "use_rfc5424_message",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "rfc3164_default_to_current_year",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "rfc5424_allow_empty_msg",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "max_message_length",
              "required": false,
              "default": 8192,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "syslog_format",
              "required": false,
              "default": "rfc5424",
              "type": {
                "kind": "string"
              }
            }
          ],
          "blocks": [
            {
              "name": "tls_config",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "ca_pem",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "ca_file",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "cert_pem",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "cert_file",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "key_pem",
                    "required": false,
                    "type": {
                      "kind": "secret"
                    }
                  },
                  {
                    "name": "key_file",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "server_name",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "insecure_skip_verify",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "min_version",
                    "required": false,
                    "type": {
                      "kind": "number"
                    }
                  }
                ]
              }
            },
            {
              "name": "raw_format_options",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "use_null_terminator_delimiter",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  }
                ]
              }
            },
            {
              "name": "rfc3164_cisco_components",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "enable_all",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "message_counter",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "sequence_number",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "hostname",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "second_fractions",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {}
}
