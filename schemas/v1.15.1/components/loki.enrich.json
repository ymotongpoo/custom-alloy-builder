{
  "name": "loki.enrich",
  "importPath": "github.com/grafana/alloy/internal/component/loki/enrich",
  "stability": "experimental",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      },
      {
        "name": "target_match_label",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "logs_match_label",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "labels_to_copy",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "forward_to",
        "required": true,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "capsule",
            "capsule": "loki.LogsReceiver",
            "goType": "loki.LogsReceiver"
          }
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "receiver",
        "required": false,
        "type": {
          "kind": "capsule",
          "capsule": "loki.LogsReceiver",
          "goType": "loki.LogsReceiver"
        }
      }
    ]
  }
}
