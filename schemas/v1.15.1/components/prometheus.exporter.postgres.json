{
  "name": "prometheus.exporter.postgres",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/exporter/postgres",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "data_source_names",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "secret"
          }
        }
      },
      {
        "name": "disable_settings_metrics",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "disable_default_metrics",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "custom_queries_config_path",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "enabled_collectors",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      }
    ],
    "blocks": [
      {
        "name": "autodiscovery",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "enabled",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "database_allowlist",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            },
            {
              "name": "database_denylist",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            }
          ]
        }
      },
      {
        "name": "stat_statements",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "include_query",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "query_length",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "limit",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "exclude_databases",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            },
            {
              "name": "exclude_users",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
