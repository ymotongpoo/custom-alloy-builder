                  },
                  {
                    "name": "insecure_skip_verify",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "min_version",
                    "required": false,
                    "type": {
                      "kind": "number"
                    }
                  }
                ]
              }
            }
          ]
