                        },
                        {
                          "name": "key_pem",
                          "required": false,
                          "type": {
                            "kind": "secret"
                          }
                        },
                        {
                          "name": "key_file",
                          "required": false,
                          "type": {
                            "kind": "string"
                          }
                        },
                        {
