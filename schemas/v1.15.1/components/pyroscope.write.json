                  {
                    "name": "ca_file",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "cert_pem",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "cert_file",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "key_pem",
                    "required": false,
                    "type": {
                      "kind": "secret"
                    }
                  },
                  {
                    "name": "key_file",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
