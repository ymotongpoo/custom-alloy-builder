                  {
                    "name": "proxy_url",
                    "required": false,
                    "type": {
                      "kind": "raw",
                      "goType": "config.URL"
                    }
                  },
                  {
                    "name": "no_proxy",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "proxy_from_environment",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
