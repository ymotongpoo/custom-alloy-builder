{
  "name": "otelcol.receiver.googlecloudpubsub",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/receiver/googlecloudpubsub",
  "stability": "undefined",
  "community": true,
  "arguments": {
    "attributes": [
      {
        "name": "project",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "user_agent",
        "required": false,
        "default": "opentelemetry-collector-contrib {{version}}",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "endpoint",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "insecure",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "subscription",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "encoding",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "compression",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "ignore_encoding_error",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "client_id",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "timeout",
        "required": false,
        "default": "12s",
        "type": {
          "kind": "duration"
        }
      }
    ],
    "blocks": [
      {
        "name": "debug_metrics",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "disable_high_cardinality_metrics",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "level",
              "required": false,
              "default": "detailed",
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      },
      {
        "name": "output",
        "required": true,
        "body": {
          "attributes": [
            {
              "name": "metrics",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.metrics",
                  "goType": "otelcol.Consumer"
                }
              }
            },
            {
              "name": "logs",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.logs",
                  "goType": "otelcol.Consumer"
                }
              }
            },
            {
              "name": "traces",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.traces",
                  "goType": "otelcol.Consumer"
                }
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "input",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "otelcol.Consumer",
          "goType": "otelcol.Consumer"
        }
      }
    ]
  }
}
