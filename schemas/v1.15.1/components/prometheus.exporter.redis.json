{
  "name": "prometheus.exporter.redis",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/exporter/redis",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "include_exporter_metrics",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "redis_addr",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "redis_user",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "redis_password",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "redis_password_file",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "redis_password_map_file",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "namespace",
        "required": false,
        "default": "redis",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "config_command",
        "required": false,
        "default": "CONFIG",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "check_keys",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "check_key_groups",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "check_key_groups_batch_size",
        "required": false,
        "default": 10000,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "max_distinct_key_groups",
        "required": false,
        "default": 100,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "check_single_keys",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "check_streams",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "check_single_streams",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "export_key_values",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "count_keys",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "script_path",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "script_paths",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "connection_timeout",
        "required": false,
        "default": "15s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "tls_client_key_file",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "tls_client_cert_file",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "tls_ca_cert_file",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "set_client_name",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "is_tile38",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "is_cluster",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "export_client_list",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "export_client_port",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "redis_metrics_only",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "ping_on_connect",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "incl_system_metrics",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "skip_tls_verification",
        "required": false,
        "type": {
          "kind": "bool"
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
