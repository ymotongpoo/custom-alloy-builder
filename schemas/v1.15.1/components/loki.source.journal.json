{
  "name": "loki.source.journal",
  "importPath": "github.com/grafana/alloy/internal/component/loki/source/journal",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "format_as_json",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "max_age",
        "required": false,
        "default": "7h0m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "path",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "relabel_rules",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "raw",
            "goType": "relabel.Config"
          }
        }
      },
      {
        "name": "matches",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "forward_to",
        "required": true,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "capsule",
            "capsule": "loki.LogsReceiver",
            "goType": "loki.LogsReceiver"
          }
        }
      },
      {
        "name": "labels",
        "required": false,
        "type": {
          "kind": "map",
          "value": {
            "kind": "string"
          }
        }
      }
    ],
    "blocks": [
      {
        "name": "legacy_position",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "file",
              "required": true,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "name",
              "required": true,
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {}
}
