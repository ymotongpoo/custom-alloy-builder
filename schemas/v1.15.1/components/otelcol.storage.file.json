{
  "name": "otelcol.storage.file",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/storage/file",
  "stability": "public-preview",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "directory",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "timeout",
        "required": false,
        "default": "1s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "fsync",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "create_directory",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "directory_permissions",
        "required": false,
        "default": "0750",
        "type": {
          "kind": "string"
        }
      }
    ],
    "blocks": [
      {
        "name": "compaction",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "on_start",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "on_rebound",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "directory",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "rebound_needed_threshold_mib",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "rebound_trigger_threshold_mib",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "max_transaction_size",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "check_interval",
              "required": false,
              "type": {
                "kind": "duration"
              }
            },
            {
              "name": "cleanup_on_start",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ]
        }
      },
      {
        "name": "debug_metrics",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "disable_high_cardinality_metrics",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "level",
              "required": false,
              "default": "detailed",
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "handler",
        "required": true,
        "type": {
          "kind": "raw",
          "goType": "extension.ExtensionHandler"
        }
      }
    ]
  }
}
