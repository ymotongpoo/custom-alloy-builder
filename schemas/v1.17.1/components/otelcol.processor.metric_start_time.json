{
  "name": "otelcol.processor.metric_start_time",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/processor/metricstarttime",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "strategy",
        "required": false,
        "default": "true_reset_point",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "gc_interval",
        "required": false,
        "default": "10m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "start_time_metric_regex",
        "required": false,
        "type": {
          "kind": "string"
        }
      }
    ],
    "blocks": [
      {
        "name": "output",
        "required": true,
        "body": {
          "attributes": [
            {
              "name": "metrics",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.metrics",
                  "goType": "otelcol.Consumer"
                }
              }
            },
            {
              "name": "logs",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.logs",
                  "goType": "otelcol.Consumer"
                }
              }
            },
            {
              "name": "traces",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.traces",
                  "goType": "otelcol.Consumer"
                }
              }
            }
          ]
        }
      },
      {
        "name": "debug_metrics",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "disable_high_cardinality_metrics",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "level",
              "required": false,
              "default": "detailed",
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "input",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "otelcol.Consumer",
          "goType": "otelcol.Consumer"
        }
      }
    ]
  }
}
