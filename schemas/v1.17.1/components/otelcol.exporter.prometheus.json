{
  "name": "otelcol.exporter.prometheus",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/exporter/prometheus",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "include_target_info",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "include_scope_info",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "include_scope_labels",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "gc_frequency",
        "required": false,
        "default": "5m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "forward_to",
        "required": true,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "capsule",
            "capsule": "prometheus.Appendable",
            "goType": "storage.Appendable"
          }
        }
      },
      {
        "name": "add_metric_suffixes",
        "required": false,
        "default": true,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "resource_to_telemetry_conversion",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "honor_metadata",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "convert_classic_histograms_to_nhcb",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "keep_identifying_resource_attributes",
        "required": false,
        "type": {
          "kind": "bool"
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "input",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "otelcol.Consumer",
          "goType": "otelcol.Consumer"
        }
      }
    ]
  }
}
