        "required": false,
        "body": {
          "attributes": [
            {
              "name": "enabled",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ],
          "blocks": [
            {
              "name": "dimension",
              "required": false,
              "multiple": true,
              "body": {
                "attributes": [
                  {
                    "name": "name",
                    "required": true,
                    "type": {
                      "kind": "string"
