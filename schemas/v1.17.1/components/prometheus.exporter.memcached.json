{
  "name": "prometheus.exporter.memcached",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/exporter/memcached",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "address",
        "required": false,
        "default": "localhost:11211",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "timeout",
        "required": false,
        "default": "1s",
        "type": {
          "kind": "duration"
        }
      }
    ],
    "blocks": [
      {
        "name": "tls_config",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "ca_pem",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "ca_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_pem",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "key_pem",
              "required": false,
              "type": {
                "kind": "secret"
              }
            },
            {
              "name": "key_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "server_name",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "insecure_skip_verify",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "min_version",
              "required": false,
              "type": {
                "kind": "number"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
