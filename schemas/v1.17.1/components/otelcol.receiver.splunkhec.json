            {
              "name": "max_age",
              "required": false,
              "type": {
                "kind": "number"
              }
            }
          ]
        }
      },
      {
        "name": "hec_metadata_to_otel_attrs",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "source",
              "required": false,
              "default": "com.splunk.source",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "sourcetype",
              "required": false,
              "default": "com.splunk.sourcetype",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "index",
              "required": false,
              "default": "com.splunk.index",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "host",
              "required": false,
              "default": "host.name",
              "type": {
                "kind": "string"
              }
            }
          ]
