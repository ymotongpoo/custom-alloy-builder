              "name": "tpm",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "enabled",
                    "required": false,
                    "type": {
                      "kind": "bool"
                    }
                  },
                  {
                    "name": "path",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "owner_auth",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  },
                  {
                    "name": "auth",
                    "required": false,
                    "type": {
                      "kind": "string"
                    }
                  }
                ]
              }
            }
          ]
        }
