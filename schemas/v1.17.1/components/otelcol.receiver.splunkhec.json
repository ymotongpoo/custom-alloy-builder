        "default": "localhost:8088",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "auth",
        "required": false,
        "type": {
          "kind": "raw",
          "goType": "auth.Handler"
        }
      },
      {
        "name": "max_request_body_size",
        "required": false,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "include_metadata",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "compression_algorithms",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "keep_alives_enabled",
