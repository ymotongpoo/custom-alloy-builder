              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "ca_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_pem",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "key_pem",
              "required": false,
              "type": {
                "kind": "secret"
              }
            },
            {
              "name": "key_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "min_version",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "max_version",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "reload_interval",
              "required": false,
              "type": {
                "kind": "duration"
              }
            },
            {
              "name": "cipher_suites",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            },
            {
