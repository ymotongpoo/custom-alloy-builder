              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "curve_preferences",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            },
            {
              "name": "client_ca_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            }
