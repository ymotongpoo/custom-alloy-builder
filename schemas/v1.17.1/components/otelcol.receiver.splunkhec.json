{
  "name": "otelcol.receiver.splunkhec",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/receiver/splunkhec",
  "stability": "public-preview",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "endpoint",
