        "required": true,
        "body": {
          "attributes": [
            {
              "name": "metrics",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.metrics",
                  "goType": "otelcol.Consumer"
                }
              }
            },
            {
              "name": "logs",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "capsule",
                  "capsule": "otelcol.Consumer.logs",
                  "goType": "otelcol.Consumer"
                }
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {}
}
