{
  "name": "pyroscope.java",
  "importPath": "github.com/grafana/alloy/internal/component/pyroscope/java",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      },
      {
        "name": "forward_to",
        "required": true,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "raw",
            "goType": "pyroscope.Appendable"
          }
        }
      },
      {
        "name": "tmp_dir",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "dist",
        "required": false,
        "type": {
          "kind": "string"
        }
      }
    ],
    "blocks": [
      {
        "name": "profiling_config",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "interval",
              "required": false,
              "type": {
                "kind": "duration"
              }
            },
            {
              "name": "sample_rate",
              "required": false,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "alloc",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "lock",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cpu",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "event",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "per_thread",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "log_level",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "quiet",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "custom_arguments",
              "required": false,
              "type": {
                "kind": "list",
                "elem": {
                  "kind": "string"
                }
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {}
}
