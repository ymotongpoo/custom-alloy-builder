{
  "name": "prometheus.echo",
  "importPath": "github.com/grafana/alloy/internal/component/prometheus/echo",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "format",
        "required": false,
        "default": "text",
        "type": {
          "kind": "string"
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "receiver",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "prometheus.Appendable",
          "goType": "storage.Appendable"
        }
      }
    ]
  }
}
