{
  "name": "discovery.openstack",
  "importPath": "github.com/grafana/alloy/internal/component/discovery/openstack",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "identity_endpoint",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "username",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "userid",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "password",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "project_name",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "project_id",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "domain_name",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "domain_id",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "application_credential_name",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "application_credential_id",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "application_credential_secret",
        "required": false,
        "type": {
          "kind": "secret"
        }
      },
      {
        "name": "role",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "region",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "refresh_interval",
        "required": false,
        "default": "1m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "port",
        "required": false,
        "default": 80,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "all_tenants",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "availability",
        "required": false,
        "default": "public",
        "type": {
          "kind": "string"
        }
      }
    ],
    "blocks": [
      {
        "name": "tls_config",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "ca_pem",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "ca_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_pem",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "key_pem",
              "required": false,
              "type": {
                "kind": "secret"
              }
            },
            {
              "name": "key_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "server_name",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "insecure_skip_verify",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "min_version",
              "required": false,
              "type": {
                "kind": "number"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
