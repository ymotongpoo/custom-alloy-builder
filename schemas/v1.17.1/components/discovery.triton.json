{
  "name": "discovery.triton",
  "importPath": "github.com/grafana/alloy/internal/component/discovery/triton",
  "stability": "generally-available",
  "community": false,
  "arguments": {
    "attributes": [
      {
        "name": "account",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "role",
        "required": false,
        "default": "container",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "dns_suffix",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "endpoint",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "groups",
        "required": false,
        "type": {
          "kind": "list",
          "elem": {
            "kind": "string"
          }
        }
      },
      {
        "name": "port",
        "required": false,
        "default": 9163,
        "type": {
          "kind": "number"
        }
      },
      {
        "name": "refresh_interval",
        "required": false,
        "default": "1m0s",
        "type": {
          "kind": "duration"
        }
      },
      {
        "name": "version",
        "required": false,
        "default": 1,
        "type": {
          "kind": "number"
        }
      }
    ],
    "blocks": [
      {
        "name": "tls_config",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "ca_pem",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "ca_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_pem",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "cert_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "key_pem",
              "required": false,
              "type": {
                "kind": "secret"
              }
            },
            {
              "name": "key_file",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "server_name",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "insecure_skip_verify",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "min_version",
              "required": false,
              "type": {
                "kind": "number"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "targets",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "discovery.Targets",
          "goType": "[]discovery.Target"
        }
      }
    ]
  }
}
