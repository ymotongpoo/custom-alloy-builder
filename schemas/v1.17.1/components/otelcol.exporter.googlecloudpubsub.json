{
  "name": "otelcol.exporter.googlecloudpubsub",
  "importPath": "github.com/grafana/alloy/internal/component/otelcol/exporter/googlecloudpubsub",
  "stability": "undefined",
  "community": true,
  "arguments": {
    "attributes": [
      {
        "name": "project",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "user_agent",
        "required": false,
        "default": "opentelemetry-collector-contrib {{version}}",
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "topic",
        "required": true,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "compression",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "endpoint",
        "required": false,
        "type": {
          "kind": "string"
        }
      },
      {
        "name": "insecure",
        "required": false,
        "type": {
          "kind": "bool"
        }
      },
      {
        "name": "timeout",
        "required": false,
        "default": "12s",
        "type": {
          "kind": "duration"
        }
      }
    ],
    "blocks": [
      {
        "name": "sending_queue",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "enabled",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "num_consumers",
              "required": false,
              "default": 10,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "queue_size",
              "required": false,
              "default": 1000,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "block_on_overflow",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "sizer",
              "required": false,
              "default": "requests",
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "wait_for_result",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "storage",
              "required": false,
              "type": {
                "kind": "raw",
                "goType": "extension.ExtensionHandler"
              }
            }
          ],
          "blocks": [
            {
              "name": "batch",
              "required": false,
              "body": {
                "attributes": [
                  {
                    "name": "flush_timeout",
                    "required": false,
                    "default": "200ms",
                    "type": {
                      "kind": "duration"
                    }
                  },
                  {
                    "name": "min_size",
                    "required": false,
                    "default": 2000,
                    "type": {
                      "kind": "number"
                    }
                  },
                  {
                    "name": "max_size",
                    "required": false,
                    "default": 3000,
                    "type": {
                      "kind": "number"
                    }
                  },
                  {
                    "name": "sizer",
                    "required": false,
                    "default": "items",
                    "type": {
                      "kind": "string"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "name": "retry_on_failure",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "enabled",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "initial_interval",
              "required": false,
              "default": "5s",
              "type": {
                "kind": "duration"
              }
            },
            {
              "name": "randomization_factor",
              "required": false,
              "default": 0.5,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "multiplier",
              "required": false,
              "default": 1.5,
              "type": {
                "kind": "number"
              }
            },
            {
              "name": "max_interval",
              "required": false,
              "default": "30s",
              "type": {
                "kind": "duration"
              }
            },
            {
              "name": "max_elapsed_time",
              "required": false,
              "default": "5m0s",
              "type": {
                "kind": "duration"
              }
            }
          ]
        }
      },
      {
        "name": "watermark",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "behavior",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "allowed_drift",
              "required": false,
              "type": {
                "kind": "duration"
              }
            }
          ]
        }
      },
      {
        "name": "ordering",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "enabled",
              "required": false,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "from_resource_attribute",
              "required": false,
              "type": {
                "kind": "string"
              }
            },
            {
              "name": "remove_resource_attribute",
              "required": false,
              "type": {
                "kind": "bool"
              }
            }
          ]
        }
      },
      {
        "name": "debug_metrics",
        "required": false,
        "body": {
          "attributes": [
            {
              "name": "disable_high_cardinality_metrics",
              "required": false,
              "default": true,
              "type": {
                "kind": "bool"
              }
            },
            {
              "name": "level",
              "required": false,
              "default": "detailed",
              "type": {
                "kind": "string"
              }
            }
          ]
        }
      }
    ]
  },
  "exports": {
    "attributes": [
      {
        "name": "input",
        "required": true,
        "type": {
          "kind": "capsule",
          "capsule": "otelcol.Consumer",
          "goType": "otelcol.Consumer"
        }
      }
    ]
  }
}
